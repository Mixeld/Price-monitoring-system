POSTGRES_DB=pricetracker
POSTGRES_USER=pricetracker
POSTGRES_PASSWORD=change_me

SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/pricetracker
SPRING_DATASOURCE_USERNAME=pricetracker
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

APP_TASK_CORE_SIZE=10
APP_TASK_MAX_SIZE=20
APP_TASK_QUEUE_CAPACITY=100
APP_TASK_THREAD_PREFIX=async-task-
APP_MAX_FILE_SIZE=10MB
APP_MAX_REQUEST_SIZE=10MB
APP_ASYNC_TIMEOUT=60000
APP_TIME_ZONE=Europe/Moscow

LOG_PATH=/app/logs
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_CONTROLLER=INFO
LOG_LEVEL_SERVICE=DEBUG
LOG_LEVEL_REPOSITORY=DEBUG
LOG_LEVEL_SPRING=WARN
LOG_LEVEL_HIBERNATE=WARN
LOG_LEVEL_SQL=WARN
LOG_LEVEL_SQL_BIND=WARN
LOG_MAX_FILE_SIZE=10MB
LOG_MAX_HISTORY=30
LOG_TOTAL_SIZE_CAP=1GB

JAVA_OPTS=-Xms256m -Xmx512m